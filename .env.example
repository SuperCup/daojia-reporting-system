# ──────────────────────────────────────
# 到家平台提报管理系统 — 环境配置
# ──────────────────────────────────────

# 数据库配置
POSTGRES_DB=daojia_reporting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# 后端配置
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/daojia_reporting
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# 初始管理员
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123456

# 前端配置
VITE_API_BASE_URL=http://localhost:8000
